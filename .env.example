# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (0 = disabled, used by default in development)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=0

# Room settings
# When 1, every new meeting requires host approval (cannot be disabled by clients)
# REQUIRE_HOST_APPROVAL=0
ROOM_TTL_MS=3600000
ROOM_CLEANUP_INTERVAL_MS=300000
# Maximum participants per meeting (mesh WebRTC; default 8)
MAX_PARTICIPANTS=8
# Meeting links expire this long after last use (default: 7 days)
MEETING_LINK_TTL_MS=604800000
# Pending join requests expire after this many milliseconds (default: 2 minutes)
# JOIN_REQUEST_TIMEOUT_MS=120000
# Recently disconnected participants can rejoin without approval for this long
# REJOIN_GRACE_MS=30000

# SQLite database for persistent meeting links
DATABASE_PATH=./data/meetings.db

# Low-resource server tuning (defaults suit 1 CPU / 1 GB RAM)
# NODE_OPTIONS=--max-old-space-size=256
# TURN_RELAY_MIN_PORT=49152
# TURN_RELAY_MAX_PORT=49202
# TURN_TOTAL_QUOTA=20
# LOG_LEVEL=warn

# coturn STUN/TURN — ICE servers are built automatically from these settings
# Dev: install coturn once, then npm run coturn:dev  or  npm run dev:with-turn
# Prod (Linux): sudo ./scripts/setup-linux-native.sh — set TURN_HOST to your public DOMAIN
TURN_HOST=localhost
TURN_REALM=video-call.local
TURN_SECRET=change-me-to-a-long-random-secret
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_USERNAME=video-call
# TURN_CREDENTIAL_TTL_SEC=86400
# TURN_EXTERNAL_IP=203.0.113.10

# Optional manual override (normally leave unset)
# ICE_SERVERS=[{"urls":"stun:localhost:3478"},{"urls":"turn:localhost:3478","username":"video-call","credential":"secret"}]

# Logging
LOG_LEVEL=info

# Frontend (optional) — override Socket.IO URL; dev defaults to same host on port 3001
# VITE_SOCKET_URL=http://localhost:3001
# VITE_BACKEND_PORT=3001

# Frontend build path (production)
FRONTEND_DIST=../frontend/dist

# HTTPS / Let's Encrypt (production)
# DOMAIN: public hostname (meet.example.com) or public IP for IP-only deploy
DOMAIN=meet.example.com
# Required for all production deploys (domain and IP-only)
CERTBOT_EMAIL=admin@example.com
# IP-only: deploy.sh requests a Let's Encrypt short-lived IP certificate (~6 days, auto-renew every 5 days)
# DEPLOY_USE_IP=1 is set automatically when DOMAIN is an IP address
# Optional: comma-separated SANs (e.g. www.meet.example.com)
# CERTBOT_EXTRA_DOMAINS=
# Set to 1 to use Let's Encrypt staging (for testing)
# CERTBOT_STAGING=0
